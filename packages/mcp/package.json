{
  "name": "@leadbay/mcp",
  "version": "0.14.1",
  "mcpName": "io.github.leadbay/leadbay-mcp",
  "description": "Model Context Protocol (MCP) server for Leadbay — AI lead discovery, qualification, and enrichment for Claude Desktop, Cursor, and Claude Code.",
  "type": "module",
  "bin": {
    "leadbay-mcp": "dist/bin.js",
    "leadbay-mcp-http": "dist/http-server.js",
    "leadbay-mcp-installer": "dist/installer-electron.js"
  },
  "files": [
    "dist/",
    "installer/electron-main.cjs",
    "README.md",
    "MIGRATION.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "pnpm --filter @leadbay/promptforge build",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test",
    "installer:gui": "pnpm run build && electron --no-sandbox installer/electron-main.cjs",
    "installer:package": "pnpm run build && electron-builder --config installer/electron-builder.cjs",
    "installer:package:linux": "pnpm run build && electron-builder --config installer/electron-builder.cjs --linux AppImage deb --publish never",
    "installer:package:mac": "pnpm run build && electron-builder --config installer/electron-builder.cjs --mac dmg --publish never",
    "installer:package:win": "pnpm run build && electron-builder --config installer/electron-builder.cjs --win nsis --publish never",
    "installer:gui:web": "pnpm run build && node dist/installer-gui.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@sentry/node": "^9.0.0",
    "hono": "^4.6.14",
    "posthog-node": "^4.5.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@leadbay/core": "workspace:*",
    "electron-builder": "^26.8.1"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "leadbay",
    "lead-generation",
    "b2b",
    "sales",
    "claude-desktop",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leadbay/leadclaw.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/leadbay/leadclaw/issues"
  },
  "homepage": "https://github.com/leadbay/leadclaw/tree/main/packages/mcp#readme",
  "author": "Leadbay",
  "license": "MIT",
  "optionalDependencies": {
    "electron": "^42.3.0"
  }
}
