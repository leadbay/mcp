{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.leadbay/leadbay-mcp",
  "title": "Leadbay",
  "description": "AI lead discovery, qualification, and outreach prep on your Leadbay account.",
  "version": "0.23.5",
  "repository": {
    "url": "https://github.com/leadbay/leadclaw",
    "source": "github",
    "subfolder": "packages/mcp"
  },
  "websiteUrl": "https://leadbay.ai",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@leadbay/mcp",
      "version": "0.23.5",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "npx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-y"
        },
        {
          "type": "positional",
          "value": "@leadbay/mcp@0.23"
        }
      ],
      "environmentVariables": [
        {
          "name": "LEADBAY_TOKEN",
          "description": "Bearer token; mint with `npx -y @leadbay/mcp@0.23 login --email <you> --region <us|fr>`.",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "LEADBAY_REGION",
          "description": "us or fr - Leadbay backend that owns your account.",
          "isRequired": true,
          "default": "fr",
          "format": "string",
          "choices": [
            "us",
            "fr"
          ]
        },
        {
          "name": "LEADBAY_MCP_WRITE",
          "description": "Set to 0 to hide composite write tools (default: 1, ON).",
          "isRequired": false,
          "default": "1"
        },
        {
          "name": "LEADBAY_MCP_ADVANCED",
          "description": "Set to 1 to expose granular API tools.",
          "isRequired": false,
          "default": "0"
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "category": "data-access",
      "tags": [
        "sales",
        "lead-generation",
        "b2b",
        "enrichment",
        "outreach"
      ]
    }
  }
}
