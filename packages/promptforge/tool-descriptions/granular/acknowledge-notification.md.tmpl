short_description: |
  Acknowledge a Leadbay notification after you've revised any prior
  output the just-finished background work might have made stale.
  Removes the notification from `_meta.notifications` and
  `account_status.notifications`, and marks it seen on the backend.
annotations:
  readOnlyHint: false
