short_description: |
  Pick the next N unqualified leads in the active lens and qualify them
  (AI rescore + web fetch). Async via wait_for_completion:false +
  qualify_id; blocking otherwise. Already-qualified leads are no-ops.
annotations:
  readOnlyHint: false
