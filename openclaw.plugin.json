{
  "id": "leadclaw",
  "name": "LeadClaw",
  "description": "Leadbay lead discovery, qualification, and contact enrichment",
  "version": "0.1.0",
  "contracts": {
    "tools": [
      "leadbay_login",
      "leadbay_list_lenses",
      "leadbay_discover_leads",
      "leadbay_get_lead_profile",
      "leadbay_get_lead_activities",
      "leadbay_get_taste_profile",
      "leadbay_get_contacts",
      "leadbay_get_quota",
      "leadbay_qualify_lead",
      "leadbay_enrich_contacts",
      "leadbay_add_note"
    ]
  },
  "uiHints": {
    "region": {
      "label": "Leadbay Region",
      "help": "Your Leadbay account region (us or fr)",
      "placeholder": "us"
    },
    "baseUrl": {
      "label": "API Base URL",
      "help": "Override API URL (for staging/dev)",
      "advanced": true
    },
    "token": {
      "label": "API Token",
      "help": "Pre-set bearer token to skip the login step",
      "sensitive": true
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "token": {
        "type": "string",
        "description": "Pre-set authentication token (Bearer) to skip login step"
      },
      "region": {
        "type": "string",
        "enum": ["us", "fr"]
      },
      "baseUrl": {
        "type": "string"
      }
    }
  }
}
